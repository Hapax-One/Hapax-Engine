ODOO_VERSION=19.0
ODOO_DB_HOST=staging-managed-postgres.internal
ODOO_DB_PORT=25060
ODOO_DB_NAME=hapax_staging
ODOO_DB_USER=hapax_staging
ODOO_DB_PASSWORD=change-me
ODOO_ADMIN_PASSWD=change-me
ODOO_WORKERS=4
ODOO_LIMIT_TIME_REAL=120
PGSSLMODE=require
PUBLIC_HOST=staging-api.gohapax.com
# Optional space-delimited aliases for temporary validation hosts
# Example: PUBLIC_HOSTS="staging-api.gohapax.com staging-api.165.227.91.131.sslip.io"
HAPAX_BASE_DOMAIN=gohapax.com
HAPAX_API_COOKIE_DOMAIN=.gohapax.com
NGINX_SSL_CERT=/etc/nginx/certs/fullchain.pem
NGINX_SSL_KEY=/etc/nginx/certs/privkey.pem
