<odoo>
    <record id="rule_hapax_vehicle_tenant_admin_company" model="ir.rule">
        <field name="name">Hapax Vehicle company scope for tenant admins</field>
        <field name="model_id" ref="model_hapax_vehicle"/>
        <field name="groups" eval="[(4, ref('hapax_core.group_hapax_tenant_admin'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_hapax_vehicle_tenant_member_company" model="ir.rule">
        <field name="name">Hapax Vehicle company scope for tenant members</field>
        <field name="model_id" ref="model_hapax_vehicle"/>
        <field name="groups" eval="[(4, ref('hapax_core.group_hapax_tenant_member'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_hapax_rate_plan_tenant_admin_company" model="ir.rule">
        <field name="name">Hapax Rate Plan company scope for tenant admins</field>
        <field name="model_id" ref="model_hapax_rate_plan"/>
        <field name="groups" eval="[(4, ref('hapax_core.group_hapax_tenant_admin'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_hapax_availability_block_tenant_admin_company" model="ir.rule">
        <field name="name">Hapax Availability company scope for tenant admins</field>
        <field name="model_id" ref="model_hapax_availability_block"/>
        <field name="groups" eval="[(4, ref('hapax_core.group_hapax_tenant_admin'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_hapax_booking_tenant_admin_company" model="ir.rule">
        <field name="name">Hapax Booking company scope for tenant admins</field>
        <field name="model_id" ref="model_hapax_booking"/>
        <field name="groups" eval="[(4, ref('hapax_core.group_hapax_tenant_admin'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_hapax_booking_tenant_member_self" model="ir.rule">
        <field name="name">Hapax Booking self scope for tenant members</field>
        <field name="model_id" ref="model_hapax_booking"/>
        <field name="groups" eval="[(4, ref('hapax_core.group_hapax_tenant_member'))]"/>
        <field name="domain_force">['|', ('customer_user_id', '=', user.id), ('customer_partner_id', '=', user.partner_id.id)]</field>
    </record>
</odoo>
