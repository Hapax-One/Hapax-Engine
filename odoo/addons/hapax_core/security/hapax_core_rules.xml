<odoo>
    <record id="rule_hapax_project_tenant_admin_company" model="ir.rule">
        <field name="name">Hapax Project company scope for tenant admins</field>
        <field name="model_id" ref="model_hapax_project"/>
        <field name="groups" eval="[(4, ref('hapax_core.group_hapax_tenant_admin'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_hapax_project_tenant_member_company" model="ir.rule">
        <field name="name">Hapax Project company scope for tenant members</field>
        <field name="model_id" ref="model_hapax_project"/>
        <field name="groups" eval="[(4, ref('hapax_core.group_hapax_tenant_member'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
