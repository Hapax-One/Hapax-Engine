<odoo>
    <record id="group_hapax_platform_admin" model="res.groups">
        <field name="name">Hapax Platform Admin</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="implied_ids" eval="[(4, ref('base.group_system'))]"/>
    </record>

    <record id="group_hapax_tenant_admin" model="res.groups">
        <field name="name">Hapax Tenant Admin</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_hapax_tenant_member" model="res.groups">
        <field name="name">Hapax Tenant Member</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
    
</odoo>
