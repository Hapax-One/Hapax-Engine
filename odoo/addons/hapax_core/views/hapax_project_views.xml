<odoo>
    <record id="view_hapax_project_tree" model="ir.ui.view">
        <field name="name">hapax.project.tree</field>
        <field name="model">hapax.project</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="company_id"/>
                <field name="slug"/>
                <field name="primary_host"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <record id="view_hapax_project_form" model="ir.ui.view">
        <field name="name">hapax.project.form</field>
        <field name="model">hapax.project</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="company_id"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="slug"/>
                            <field name="primary_host"/>
                            <field name="website_url"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Brand">
                        <group>
                            <field name="brand_name"/>
                            <field name="brand_color"/>
                            <field name="logo_url"/>
                        </group>
                        <group>
                            <field name="support_email"/>
                            <field name="support_phone"/>
                        </group>
                    </group>
                    <group string="Routing">
                        <field name="alias_hosts" placeholder="one.example.com&#10;two.example.com"/>
                    </group>
                    <group string="Metadata">
                        <field name="metadata_json" nolabel="1" placeholder="{}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hapax_projects" model="ir.actions.act_window">
        <field name="name">Hapax Projects</field>
        <field name="res_model">hapax.project</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        id="menu_hapax_root"
        name="Hapax"
        parent="base.menu_administration"
        groups="hapax_core.group_hapax_platform_admin,hapax_core.group_hapax_tenant_admin"
    />

    <menuitem
        id="menu_hapax_projects"
        name="Projects"
        parent="hapax_core.menu_hapax_root"
        action="hapax_core.action_hapax_projects"
        groups="hapax_core.group_hapax_platform_admin"
    />
</odoo>
